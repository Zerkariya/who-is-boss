{
  "name": "who-is-boss",
  "version": "0.1.0",
  "description": "Multi-agent CLI orchestration: one boss writes code, others handle review, research, and Q&A — to save the boss's context window.",
  "type": "module",
  "bin": {
    "who-is-boss": "dist/cli.js",
    "wib": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "npm run build && node --import tsx --test test/unit/*.test.ts test/integration/*.test.ts",
    "test:unit": "node --import tsx --test test/unit/*.test.ts",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "examples"
  ],
  "keywords": [
    "ai",
    "agent",
    "orchestration",
    "claude",
    "codex",
    "gemini",
    "deepseek",
    "cli",
    "multi-agent"
  ],
  "author": "",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Zerkariya/who-is-boss.git"
  },
  "dependencies": {
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
